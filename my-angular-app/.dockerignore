# Dependencies — reinstalled inside the build stage
node_modules

# Previous build output — Docker builds a fresh one
dist

# Version control
.git
.gitignore

# IDE / editor files
.vscode
.idea
*.suo
*.ntvs*
*.njsproj
*.sln

# Test & coverage output
coverage
.nyc_output

# Env files — never bake secrets into an image
.env
.env.*
!.env.example

# OS noise
.DS_Store
Thumbs.db

# Angular cache
.angular